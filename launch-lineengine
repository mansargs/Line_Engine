#!/bin/bash
ENGINE_PATH="$(dirname "$0")/build/bin/LineEngine"
WORK_DIR="$(dirname "$0")"

cd "$WORK_DIR" || {
	zenity --error --title="LineEngine Error" --text="Failed to set working directory:\n$WORK_DIR" 2>/dev/null
	exit 1
}

show_error() {
	if command -v zenity &> /dev/null; then
		zenity --error --title="LineEngine Error" --text="$1" 2>/dev/null
	else
		echo "$1" >&2
	fi
}

if [ ! -f "$ENGINE_PATH" ]; then
	show_error "LineEngine binary not found at:\n$ENGINE_PATH"
	exit 1
fi

if [ -z "$1" ]; then
	if command -v zenity &> /dev/null; then
		SELECTED_FILE=$(zenity --file-selection \
			--title="Select a LineEngine map file" \
			--filename="$WORK_DIR/test_maps/" 2>/dev/null)
		ZENITY_EXIT=$?
		if [ $ZENITY_EXIT -ne 0 ] || [ -z "$SELECTED_FILE" ]; then
			exit 0
		fi
	else
		SELECTED_FILE=$(ls "$WORK_DIR/test_maps/"*.lge 2>/dev/null | head -1)
		if [ -z "$SELECTED_FILE" ]; then
			show_error "No .lge files found in test_maps/.\nPlease add one or install zenity."
			exit 1
		fi
	fi

	if [ ! -f "$SELECTED_FILE" ]; then
		show_error "Selected file not found:\n$SELECTED_FILE"
		exit 1
	fi

	ERROR_OUTPUT=$("$ENGINE_PATH" "$SELECTED_FILE" 2>&1)
	EXIT_CODE=$?
	ERROR_OUTPUT=$(echo "$ERROR_OUTPUT" | sed 's/\x1b\[[0-9;]*m//g')
	if [ $EXIT_CODE -ne 0 ]; then
		show_error "Failed to open file:\n$SELECTED_FILE\n\n$ERROR_OUTPUT"
		exit $EXIT_CODE
	fi
else
	if [ ! -f "$1" ]; then
		show_error "File not found:\n$1"
		exit 1
	fi

	ERROR_OUTPUT=$("$ENGINE_PATH" "$1" 2>&1)
	EXIT_CODE=$?
	ERROR_OUTPUT=$(echo "$ERROR_OUTPUT" | sed 's/\x1b\[[0-9;]*m//g')
	if [ $EXIT_CODE -ne 0 ]; then
		show_error "Failed to open file:\n$1\n\n$ERROR_OUTPUT"
		exit $EXIT_CODE
	fi
fi
